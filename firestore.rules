rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net - catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation rules for transaction
    function isValidTransaction(data) {
      return data.userId is string &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.amount >= 0 &&
             data.type is string &&
             (data.type == 'income' || data.type == 'expense') &&
             data.category is string &&
             data.category.size() <= 100 &&
             data.note is string &&
             data.note.size() <= 500 &&
             data.date is string &&
             data.date.size() <= 20;
    }

    // Validation rules for budget
    function isValidBudget(data) {
      return data.userId is string &&
             data.userId == request.auth.uid &&
             data.category is string &&
             data.category.size() <= 100 &&
             data.amount is number &&
             data.amount >= 0;
    }

    // Validation rules for goal
    function isValidGoal(data) {
      return data.userId is string &&
             data.userId == request.auth.uid &&
             data.name is string &&
             data.name.size() <= 100 &&
             data.target is number &&
             data.target >= 0 &&
             data.current is number &&
             data.current >= 0 &&
             data.targetDate is string &&
             data.targetDate.size() <= 20;
    }

    // Validation rules for customCategory
    function isValidCategory(data) {
      return data.userId is string &&
             data.userId == request.auth.uid &&
             data.name is string &&
             data.name.size() <= 100 &&
             data.type is string &&
             (data.type == 'income' || data.type == 'expense');
    }

    // User scope matches
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);

      match /transactions/{transactionId} {
        allow read, write: if isOwner(userId);
      }

      match /budgets/{categoryId} {
        allow read, write: if isOwner(userId);
      }

      match /goals/{goalId} {
        allow read, write: if isOwner(userId);
      }

      match /categories/{categoryId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
